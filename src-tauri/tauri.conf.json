{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebP 转 GIF",
  "version": "1.0.0",
  "identifier": "com.codex.webp-to-gif",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WebP 转 GIF",
        "width": 980,
        "height": 680,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
